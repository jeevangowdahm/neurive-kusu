# 1. Supabase Client Configurations (Required for client and server)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your-anon-key

# 2. Large Language Model Integration (Optional but recommended for RAG Chat)
# Obtain from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere

# 3. Vector Embeddings Generation (Optional; defaults to simulated vectors if missing)
