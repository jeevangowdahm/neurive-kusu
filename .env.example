# Neurive Environment Variables
# Copy this to .env and fill in your actual values
# NEVER commit .env to GitHub

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Gemini API Keys
GEMINI_API_KEY=your-gemini-api-key
GEMINI_KEY_SEARCH=your-gemini-search-key
GEMINI_KEY_AGENT=your-gemini-agent-key
GEMINI_KEY_CHAT=your-gemini-chat-key
GEMINI_KEY_FINDING=your-gemini-finding-key
GEMINI_KEY_GRAPH=your-gemini-graph-key
GEMINI_KEY_OTHER=your-gemini-other-key

# OpenAI API Key
OPENAI_API_KEY=your-openai-api-key

# Google Custom Search
GOOGLE_SEARCH_API_KEY=your-google-search-api-key
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id

# Agent Sandbox Mode
ENABLE_AGENT_SANDBOX=false

# App Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Neurive
